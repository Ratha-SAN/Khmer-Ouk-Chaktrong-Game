rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow create: if true;
      allow update: if true;
      allow read, delete: if false;
    }
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /games/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    // Public matchmaking lobbies: anyone signed in can browse open ones
    // (needed to find a quick match or look up a code), only the host can
    // touch their own lobby otherwise, and claiming an open one (becoming
    // its guest) is the one write a non-host is allowed to make.
    match /lobbies/{lobbyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.hostUid == request.auth.uid ||
        (resource.data.status == 'open' && request.resource.data.guestUid == request.auth.uid)
      );
      allow delete: if request.auth != null && resource.data.hostUid == request.auth.uid;
    }
    // Live match state: only the two matched players can ever read or
    // write their own game document.
    match /matches/{matchId} {
      allow create: if request.auth != null && (
        request.resource.data.players.white == request.auth.uid ||
        request.resource.data.players.black == request.auth.uid
      );
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.players.white ||
        request.auth.uid == resource.data.players.black
      );
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
